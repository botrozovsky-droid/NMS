# Environment variables (contains API keys)
.env
.env.local
.env.*.local

# Dependencies
node_modules/
package-lock.json

# User data directories (contains personal/private data)
hippocampus/
neocortex/
meta/

# Keep directory structure but ignore contents
!hippocampus/.gitkeep
!neocortex/.gitkeep
!meta/.gitkeep

# Backups
*.backup
*.backup.*
.tx-backups/

# Exports
exports/

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp

# OS-specific files
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# IDE-specific files
# VSCode
.vscode/
*.code-workspace

# JetBrains IDEs
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Test coverage
coverage/
.nyc_output/

# Build outputs
dist/
build/

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
